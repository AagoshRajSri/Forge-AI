generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime

  sessions Session[]
  accounts Account[]

  projects     WebsiteProject[]
  transactions Transaction[]
  jobs         JobTracker[]

  totalCreation Int @default(0)
  credits       Int @default(20)

  @@map("user")
}

model WebsiteProject {
  id             String  @id @default(uuid())
  name           String
  initial_prompt String
  userId         String
  isPublished    Boolean @default(false)
  current_code   String?
  current_version_index String? @default("0")

  conversation Conversation[]
  branches     Branch[]
  components   Component[]
  jobs         JobTracker[]

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Branch {
  id        String         @id @default(uuid())
  name      String         @default("main")
  isDefault Boolean        @default(false)
  projectId String
  project   WebsiteProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  versions Version[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, name])
}

model Version {
  id          String   @id @default(uuid())
  patch       String // JSON patch or unified diff string
  fullHtml    String? // Optional snapshot for faster rendering on major versions
  description String?
  timestamp   DateTime @default(now())

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  parentId String? // For git-like history
  parent   Version?  @relation("VersionHistory", fields: [parentId], references: [id])
  children Version[] @relation("VersionHistory")
}

model Component {
  id       String  @id @default(uuid())
  name     String // e.g., "Hero", "Navbar"
  code     String // HTML + Tailwind
  metadata String? // JSON string for specific component properties

  projectId String
  project   WebsiteProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, name])
}

enum Role {
  user
  assistant
}

model Conversation {
  id        String         @id @default(uuid())
  role      Role
  content   String
  timestamp DateTime       @default(now())
  projectId String
  project   WebsiteProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model JobTracker {
  id       String    @id @default(uuid())
  type     String // e.g., "GENERATE_COMPONENT", "PLANNING"
  status   JobStatus @default(PENDING)
  progress Int       @default(0)
  data     String? // Input JSON
  result   String? // Output JSON
  error    String? // Error message if failed

  projectId String
  project   WebsiteProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TransactionType {
  TOPUP
  FULL_PAGE_GEN
  COMPONENT_EDIT
  REPAIR
}

model Transaction {
  id         String          @id @default(uuid())
  type       TransactionType @default(TOPUP)
  isPaid     Boolean         @default(false) // Relevant for TOPUP
  planId     String?
  amount     Float? // Money amount for TOPUP
  credits    Int // Credits added or subtracted
  tokensUsed Int? // Track exact LLM token usage

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- Better Auth Models ---

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}
